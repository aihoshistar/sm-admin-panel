# ==============================================================================
# SM Admin Panel - Laravel Environment Configuration
# ==============================================================================
# 루트 .env 파일의 공통 설정을 사용하며, Laravel 특화 설정만 포함
# ==============================================================================

# ------------------------------------------------------------------------------
# Laravel 애플리케이션 설정
# ------------------------------------------------------------------------------
APP_NAME="SM Artist Insights Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=ko
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ko_KR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# 데이터베이스 설정
# ------------------------------------------------------------------------------
# 루트 .env의 DB 설정을 우선 사용
# 로컬 개발 시에만 아래 값으로 오버라이드
DB_CONNECTION=mysql
DB_HOST=${DB_HOST:-127.0.0.1}
DB_PORT=${DB_PORT:-3306}
DB_DATABASE=${DB_DATABASE:-sm_artist_insights}
DB_USERNAME=${DB_USERNAME:-root}
DB_PASSWORD=${DB_PASSWORD:-password}

# ------------------------------------------------------------------------------
# 로깅
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=${LOG_LEVEL:-debug}

# ------------------------------------------------------------------------------
# 세션 설정
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ------------------------------------------------------------------------------
# 캐시 & 큐 설정
# ------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ------------------------------------------------------------------------------
# 메일 설정 (개발 환경)
# ------------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sm-artist-insights.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Vite (프론트엔드 빌드)
# ------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Redis (선택 사항 - 사용 시 주석 해제)
# ------------------------------------------------------------------------------
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ------------------------------------------------------------------------------
# AWS S3 (파일 업로드 시 사용 - 선택 사항)
# ------------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-northeast-2
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false
